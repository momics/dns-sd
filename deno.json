{
  "workspace": [
    "packages/dns-sd-shared",
    "packages/dns-sd-deno"
  ],
  "nodeModulesDir": "none",
  "fmt": {
    "include": ["packages"],
    "exclude": [
      "**/node_modules",
      "**/dist",
      "**/dist-js",
      "**/dist-test",
      "**/gen",
      "**/target",
      "**/permissions/schemas",
      "**/*.xml",
      "**/*.md",
      "packages/dns-sd-node/examples",
      "packages/dns-sd-tauri/examples"
    ]
  },
  "lint": {
    "include": ["packages"],
    "exclude": [
      "**/node_modules",
      "**/dist",
      "**/dist-js",
      "**/dist-test",
      "**/gen",
      "**/target",
      "packages/dns-sd-node/examples",
      "packages/dns-sd-tauri/examples"
    ]
  },
  "tasks": {
    "test": "deno task test:shared && deno task test:deno-runtime && deno task test:tauri",
    "test:shared": "deno task --cwd packages/dns-sd-shared test",
    "test:deno-runtime": "deno task --cwd packages/dns-sd-deno test",
    "test:tauri": "deno task --cwd packages/dns-sd-tauri test",
    "check": "deno task --cwd packages/dns-sd-shared check",
    "check:deno-runtime": "deno task --cwd packages/dns-sd-deno check",
    "check:tauri": "deno task --cwd packages/dns-sd-tauri check",
    "check:docs": "deno task --cwd packages/dns-sd-shared check:docs",
    "check:api": "deno task --cwd packages/dns-sd-shared check:api",
    "snapshot:api": "deno task --cwd packages/dns-sd-shared snapshot:api",
    "bench": "deno task --cwd packages/dns-sd-shared bench",
    "perf:gate": "deno task --cwd packages/dns-sd-shared perf:gate",
    "perf:baseline": "deno task --cwd packages/dns-sd-shared perf:baseline"
  }
}
