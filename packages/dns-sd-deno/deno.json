{
  "name": "@momics/dns-sd-deno",
  "version": "0.1.0",
  "license": "MIT",
  "compilerOptions": {
    "lib": ["deno.window", "deno.ns", "deno.unstable", "esnext.disposable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "check": "deno check src/mod.ts examples/browse.ts examples/advertise.ts test/run.ts test/transport_test.ts test/conformance_test.ts",
    "test": "deno run --unstable-net --allow-net --allow-sys --allow-env test/run.ts",
    "test:network": "DNS_SD_NETWORK_TESTS=1 deno run --unstable-net --allow-net --allow-sys --allow-env test/run.ts",
    "example:browse": "deno run --unstable-net --allow-net --allow-sys examples/browse.ts",
    "example:advertise": "deno run --unstable-net --allow-net --allow-sys examples/advertise.ts"
  },
  "publish": {
    "include": ["src/", "README.md", "deno.json"]
  }
}
