{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "ES2024.Promise", "ESNext.Disposable", "DOM"],
    "types": [],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist-js",
    "rootDir": "./guest-js",
    "skipLibCheck": true
  },
  "include": ["guest-js/**/*"],
  "exclude": ["node_modules", "dist-js", "guest-js/**/*.test.ts"]
}
