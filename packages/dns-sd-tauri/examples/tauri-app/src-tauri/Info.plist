<plist version="1.0">
<dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>This app uses the local network to discover and advertise services using mDNS/Bonjour.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
		<string>_musc._tcp</string>
		<string>_musp._tcp</string>
	</array>
