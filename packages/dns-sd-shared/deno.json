{
  "name": "@momics/dns-sd-shared",
  "version": "0.1.0",
  "license": "MIT",
  "compilerOptions": {
    "lib": ["deno.window", "deno.ns", "esnext.disposable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "exports": {
    ".": "./src/index.ts",
    "./wire": "./src/wire/index.ts",
    "./testing": "./src/testing/index.ts",
    "./testing/harness": "./src/testing/harness.ts"
  },
  "tasks": {
    "test": "deno run test/run.ts",
    "check": "deno check src/index.ts src/wire/index.ts src/testing/index.ts src/testing/harness.ts test/run.ts",
    "check:docs": "deno doc --lint src/index.ts src/wire/index.ts src/testing/index.ts src/testing/harness.ts",
    "check:api": "deno run -A scripts/api-snapshot.ts --check",
    "snapshot:api": "deno run -A scripts/api-snapshot.ts --write"
  },
  "publish": {
    "include": ["src/", "README.md", "deno.json"]
  }
}
