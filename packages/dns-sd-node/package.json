{
  "name": "@momics/dns-sd-node",
  "version": "0.1.0",
  "description": "Node.js runtime adapter for @momics/dns-sd-shared: a UDP-multicast DatagramTransport (via node:dgram) driving the shared, standards-compliant mDNS / DNS-SD engine.",
  "keywords": [
    "dns-sd",
    "mdns",
    "bonjour",
    "zeroconf",
    "discovery",
    "service-discovery",
    "multicast-dns",
    "node",
    "dgram"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test:node": "npm run build && node dist/test/run.js"
  },
  "files": ["dist", "src", "README.md"],
  "dependencies": {
    "@momics/dns-sd-shared": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/momics/dns-sd.git"
  },
  "homepage": "https://github.com/momics/dns-sd"
}
